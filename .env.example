APP_NAME="LGU Alicia LMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://lms.alicia.local

APP_LOCALE=en
APP_TIMEZONE=Asia/Manila

# --- Database (XAMPP MySQL/MariaDB) -----------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lms_alicia
DB_USERNAME=root
DB_PASSWORD=

# --- Sessions, cache, queue -------------------------------------------------
# database drivers work out-of-the-box on XAMPP (no Redis needed).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# To use Redis instead (optional, faster):
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# --- Mail (for OTP + notifications) -----------------------------------------
# During first setup you can use "log" to read OTPs from storage/logs/laravel.log.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=25
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@alicia.gov.ph"
MAIL_FROM_NAME="${APP_NAME}"

# --- Seed super admin password (used once by CoreUserSeeder) ----------------
SEED_SUPERADMIN_PASSWORD="ChangeMe!Alicia2026"
